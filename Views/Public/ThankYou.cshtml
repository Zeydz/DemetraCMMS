@using dotnet_projektuppgift.Models.Enums
@model dotnet_projektuppgift.Models.Entities.Ticket

@{
    ViewData["Title"] = "Request Submitted";
    Layout = "~/Views/Shared/_LayoutPublic.cshtml";
}

<style>
    body {
        font-family: 'Exo 2', sans-serif;
    }

    .mono {
        font-family: 'Saira', sans-serif;
    }

    .dot {
        width: 6px;
        height: 6px;
        background: #02f1b4;
        display: inline-block;
        flex-shrink: 0;
    }
</style>

<section class="bg-white min-h-screen py-20">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">

        @* Success icon *@
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-20 h-20 bg-green-50 border-2 border-green-500 mb-6">
                <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
            </div>
            
            <div class="flex items-center gap-3 justify-center mb-3">
                <span class="dot"></span>
                <span class="mono text-xs tracking-[0.25em] text-[#02f1b4] uppercase">Request Submitted</span>
            </div>
            
            <h1 class="text-4xl font-black text-[#041f41] mb-4">
                Thank You!
            </h1>
            <p class="text-gray-600 text-lg">
                Your service request has been received and logged.
            </p>
        </div>

        @* Ticket details box *@
        <div class="bg-[#041f41] text-white p-8 mb-8">
            <div class="text-center mb-6">
                <div class="mono text-xs tracking-[0.25em] text-[#02f1b4] uppercase mb-2">
                    Your Ticket Number
                </div>
                <div class="text-5xl font-black text-[#02f1b4]">
                    #@Model.Id
                </div>
            </div>
            
            <div class="border-t border-white/10 pt-6 space-y-4">
                <div class="flex justify-between items-start">
                    <div class="mono text-xs tracking-widest uppercase text-gray-400">Issue</div>
                    <div class="text-sm font-bold text-right">@Model.Title</div>
                </div>
                
                <div class="flex justify-between items-start">
                    <div class="mono text-xs tracking-widest uppercase text-gray-400">Equipment</div>
                    <div class="text-sm text-right">@Model.Equipment?.Name</div>
                </div>
                
                <div class="flex justify-between items-start">
                    <div class="mono text-xs tracking-widest uppercase text-gray-400">Priority</div>
                    <div>
                        @{
                            var priorityClass = Model.Priority switch
                            {
                                TicketPriority.Critical => "bg-red-500",
                                TicketPriority.High => "bg-orange-500",
                                TicketPriority.Medium => "bg-yellow-500",
                                _ => "bg-blue-500"
                            };
                        }
                        <span class="mono inline-block px-2 py-1 text-[10px] font-bold tracking-widest uppercase @priorityClass text-white">
                            @Model.Priority
                        </span>
                    </div>
                </div>
                
                <div class="flex justify-between items-start">
                    <div class="mono text-xs tracking-widest uppercase text-gray-400">Expected Response</div>
                    <div class="text-sm mono text-[#02f1b4]">
                        @Model.DueDate.ToString("MMM dd, yyyy HH:mm")
                    </div>
                </div>
            </div>
        </div>

        @* What happens next *@
        <div class="bg-gray-50 border-2 border-gray-200 p-8 mb-8">
            <h3 class="font-bold text-[#041f41] mb-6">What happens next?</h3>
            
            <ol class="space-y-4">
                <li class="flex gap-4">
                    <span class="mono text-[#02f1b4] font-black shrink-0">01</span>
                    <div class="text-sm text-gray-700">
                        <strong>Technician assignment</strong> — A qualified technician will be assigned based on your issue type
                    </div>
                </li>
                <li class="flex gap-4">
                    <span class="mono text-[#02f1b4] font-black shrink-0">02</span>
                    <div class="text-sm text-gray-700">
                        <strong>Issue resolution</strong> — Work will be completed within the priority window
                    </div>
                </li>
                <li class="flex gap-4">
                    <span class="mono text-[#02f1b4] font-black shrink-0">03</span>
                    <div class="text-sm text-gray-700">
                        <strong>Check back</strong> — Check ticket status to see if ticket has been resolved
                    </div>
                </li>
            </ol>
        </div>

        @* Action buttons *@
        <div class="flex flex-col sm:flex-row gap-4">
            <a asp-controller="Public" asp-action="Index"
               class="flex-1 text-center border-2 border-[#041f41] text-[#041f41] py-3
                      mono font-black text-xs tracking-widest uppercase
                      hover:bg-[#041f41] hover:text-[#02f1b4] transition">
                ← Back to Home
            </a>
            
            <a asp-controller="Public" asp-action="CheckStatus"
               class="flex-1 text-center bg-[#041f41] text-[#02f1b4] py-3
                      mono font-black text-xs tracking-widest uppercase
                      hover:bg-[#02f1b4] hover:text-[#041f41] transition border-2 border-[#041f41]">
                Check Ticket Status →
            </a>
        </div>

        @* Save ticket number reminder *@
        <div class="mt-8 text-center">
            <p class="text-xs text-gray-500">
                Save your ticket number <strong class="text-[#041f41]">#@Model.Id</strong> to track your request
            </p>
        </div>

    </div>
</section>
