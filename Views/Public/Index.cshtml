@using dotnet_projektuppgift.Models.Entities
@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_LayoutPublic.cshtml";
}

<style>
    body {
        font-family: 'Exo 2', sans-serif;
    }

    .mono {
        font-family: 'Saira', sans-serif;
    }

    .ticker-line {
        animation: ticker 18s linear infinite;
        white-space: nowrap;
    }

    @@keyframes ticker {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(-50%);
        }
    }

    input:focus, select:focus, textarea:focus {
        outline: 2px solid #02f1b4;
        outline-offset: 0;
    }

    .dot {
        width: 6px;
        height: 6px;
        background: #02f1b4;
        display: inline-block;
        flex-shrink: 0;
    }

    input[type="radio"].sr-only:checked + div {
        border-color: currentColor;
    }

</style>

@* Hero Section*@
<section class="bg-[#041f41] text-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 pt-20 pb-16">

        @* Short green text *@
        <div class="flex items-center gap-3 mb-8">
            <span class="dot"></span>
            <span class="mono text-xs tracking-[0.25em] text-[#02f1b4] uppercase">
                Facility Management System
            </span>
        </div>

        @* Heading *@
        <div class="max-w-3xl">
            <h1 class="text-6xl font-black leading-none tracking-tight mb-6">
                Report an issue.<br>
                <span class="text-[#02f1b4]">We'll handle it.</span>
            </h1>
            <p class="text-gray-400 text-lg leading-relaxed max-w-xl">
                Submit service requests, track equipment maintenance,
                and stay updated on every repair, all in one place.
            </p>
        </div>

        @* Divider *@
        <div class="border-t border-white/10 mt-12"></div>

        @* Response time stats*@
        <div class="grid grid-cols-3 divide-x divide-white/10 mt-0">
            <div class="pr-8 pt-8">
                <div class="text-4xl font-black text-[#02f1b4]">4h</div>
                <div class="mono text-xs text-gray-400 mt-1 tracking-widest uppercase">Critical Response</div>
            </div>
            <div class="px-8 pt-8">
                <div class="text-4xl font-black">24h</div>
                <div class="mono text-xs text-gray-400 mt-1 tracking-widest uppercase">High Priority</div>
            </div>
            <div class="pl-8 pt-8">
                <div class="text-4xl font-black">7d</div>
                <div class="mono text-xs text-gray-400 mt-1 tracking-widest uppercase">Low Priority</div>
            </div>
        </div>

    </div>
</section>

@* Ticker, found it here: https://codepen.io/bertofern/pen/xxEpQGM*@
<div class="bg-[#02f1b4] overflow-hidden py-2.5">
    <div class="ticker-line flex gap-10 text-[#041f41] text-xs font-black tracking-[0.2em] uppercase mono">
        <span>Electrical</span><span>·</span>
        <span>HVAC</span><span>·</span>
        <span>Plumbing</span><span>·</span>
        <span>IT Infrastructure</span><span>·</span>
        <span>Carpentry</span><span>·</span>
        <span>General Maintenance</span><span>·</span>
        <span>Fire Safety</span><span>·</span>
        <span>Elevators</span><span>·</span>
        @* Duplicate to make it a seemless loop*@
        <span>Electrical</span><span>·</span>
        <span>HVAC</span><span>·</span>
        <span>Plumbing</span><span>·</span>
        <span>IT Infrastructure</span><span>·</span>
        <span>Carpentry</span><span>·</span>
        <span>General Maintenance</span><span>·</span>
        <span>Fire Safety</span><span>·</span>
        <span>Elevators</span><span>·</span>
    </div>
</div>

@* Main content *@
<section class="bg-white py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        @* Error handling*@
        @if (TempData["Error"] != null)
        {
            <div class="mb-8 bg-red-50 border-2 border-red-200 p-4">
                <div class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-red-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <p class="text-sm font-semibold text-red-800">@TempData["Error"]</p>
                </div>
            </div>
        }
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-16">

            @* Left side - FORM*@
            <div class="lg:col-span-3">

                <div class="flex items-center gap-3 mb-2">
                    <span class="dot"></span>
                    <span class="mono text-xs tracking-[0.25em] text-[#02f1b4] uppercase">New Request</span>
                </div>
                <h2 class="text-4xl font-black text-[#041f41] mb-8 leading-tight">
                    Submit a Service Request
                </h2>

                <form method="post" asp-controller="Public" asp-action="SubmitTicket" class="space-y-5">

                    @* Name + Email*@
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <div>
                            <label class="block mono text-xs font-bold text-[#041f41] tracking-widest uppercase mb-2">
                                Full Name <span class="text-[#02f1b4]">*</span>
                            </label>
                            <input type="text" name="ContactName" required
                                   class="w-full px-4 py-3 border-2 border-gray-200 bg-gray-50 text-[#041f41] font-medium focus:bg-white transition"
                                   placeholder="John Doe">
                        </div>
                        <div>
                            <label class="block mono text-xs font-bold text-[#041f41] tracking-widest uppercase mb-2">
                                Email <span class="text-[#02f1b4]">*</span>
                            </label>
                            <input type="email" name="ContactEmail" required
                                   class="w-full px-4 py-3 border-2 border-gray-200 bg-gray-50 text-[#041f41] font-medium focus:bg-white transition"
                                   placeholder="john@example.com">
                        </div>
                    </div>

                    @* Phone *@
                    <div>
                        <label class="block mono text-xs font-bold text-[#041f41] tracking-widest uppercase mb-2">
                            Phone Number
                        </label>
                        <input type="tel" name="ContactPhone"
                               class="w-full px-4 py-3 border-2 border-gray-200 bg-gray-50 text-[#041f41] font-medium focus:bg-white transition"
                               placeholder="+46 70 123 45 67">
                    </div>

                    @* Equipment *@
                    <div>
                        <label class="block mono text-xs font-bold text-[#041f41] tracking-widest uppercase mb-2">
                            Equipment <span class="text-[#02f1b4]">*</span>
                        </label>
                        <select name="EquipmentId" required
                                class="w-full px-4 py-3 border-2 border-gray-200 bg-gray-50 text-[#041f41] font-medium focus:bg-white transition">
                            <option value="">— Select equipment —</option>
                            @if (ViewData["Equipment"] != null)
                            {
                                @foreach (var eq in ViewData["Equipment"] as List<Equipment>)
                                {
                                    <option value="@eq.Id">@eq.Name — @eq.Location?.Name</option>
                                }
                            }
                        </select>
                    </div>

                    @* Issue title *@
                    <div>
                        <label class="block mono text-xs font-bold text-[#041f41] tracking-widest uppercase mb-2">
                            Issue Summary <span class="text-[#02f1b4]">*</span>
                        </label>
                        <input type="text" name="Title" required
                               class="w-full px-4 py-3 border-2 border-gray-200 bg-gray-50 text-[#041f41] font-medium focus:bg-white transition"
                               placeholder="e.g. HVAC not cooling properly">
                    </div>

                    @* Description *@
                    <div>
                        <label class="block mono text-xs font-bold text-[#041f41] tracking-widest uppercase mb-2">
                            Description <span class="text-[#02f1b4]">*</span>
                        </label>
                        <textarea name="Description" rows="5" required
                                  class="w-full px-4 py-3 border-2 border-gray-200 bg-gray-50 text-[#041f41] font-medium focus:bg-white transition resize-none"
                                  placeholder="Describe the issue, when it started, what you've noticed, how urgent it feels…"></textarea>
                    </div>

                    @* Priority selector*@
                    <div>
                        <label class="block mono text-xs font-bold text-[#041f41] tracking-widest uppercase mb-3">
                            Priority <span class="text-[#02f1b4]">*</span>
                        </label>
                        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">

                            <label class="cursor-pointer">
                                <input type="radio" name="Priority" value="0" class="sr-only peer" required>
                                <span class="block border-2 border-gray-200 px-3 py-3 text-center transition
                peer-checked:border-[#22c55e] peer-checked:bg-[#22c55e] peer-checked:text-white">
                                    <span class="block mono text-xs font-black tracking-widest uppercase">Low</span>
                                    <span class="block text-xs mt-1">7 days</span>
                                </span>
                            </label>

                            <label class="cursor-pointer">
                                <input type="radio" name="Priority" value="1" class="sr-only peer">
                                <span class="block border-2 border-gray-200 px-3 py-3 text-center transition
                peer-checked:border-[#eab308] peer-checked:bg-[#eab308] peer-checked:text-white">
                                    <span class="block mono text-xs font-black tracking-widest uppercase">Medium</span>
                                    <span class="block text-xs mt-1">3 days</span>
                                </span>
                            </label>

                            <label class="cursor-pointer">
                                <input type="radio" name="Priority" value="2" class="sr-only peer">
                                <span class="block border-2 border-gray-200 px-3 py-3 text-center transition
                peer-checked:border-[#f97316] peer-checked:bg-[#f97316] peer-checked:text-white">
                                    <span class="block mono text-xs font-black tracking-widest uppercase">High</span>
                                    <span class="block text-xs mt-1">24 hours</span>
                                </span>
                            </label>

                            <label class="cursor-pointer">
                                <input type="radio" name="Priority" value="3" class="sr-only peer">
                                <span class="block border-2 border-gray-200 px-3 py-3 text-center transition
                peer-checked:border-[#dc2626] peer-checked:bg-[#dc2626] peer-checked:text-white">
                                    <span
                                        class="block mono text-xs font-black tracking-widest uppercase">Critical</span>
                                    <span class="block text-xs mt-1">4 hours</span>
                                </span>
                            </label>

                        </div>
                    </div>

                    @* Submit button *@
                    <div class="pt-2">
                        <button type="submit"
                                class="cursor-pointer w-full bg-[#041f41] text-[#02f1b4] py-4 mono font-black text-sm tracking-widest uppercase
                                       hover:bg-[#02f1b4] hover:text-[#041f41] transition border-2 border-[#041f41]">
                            Submit Service Request →
                        </button>
                    </div>

                </form>
            </div>

            @* Right - INFO PANEL*@
            <div class="lg:col-span-2 space-y-6">

                @* What happens next *@
                <div class="bg-[#041f41] text-white p-8">
                    <div class="flex items-center gap-3 mb-6">
                        <span class="dot"></span>
                        <span class="mono text-xs tracking-[0.25em] text-[#02f1b4] uppercase">What happens next</span>
                    </div>
                    <ol class="space-y-7">
                        <li class="flex gap-4">
                            <span class="text-[#02f1b4] font-black text-2xl leading-none mono shrink-0">01</span>
                            <div>
                                <div class="font-bold text-sm mb-1">Request received</div>
                                <div class="text-gray-400 text-sm leading-relaxed">
                                    Your ticket is logged and assigned a tracking number immediately.
                                </div>
                            </div>
                        </li>
                        <li class="flex gap-4">
                            <span class="text-[#02f1b4] font-black text-2xl leading-none mono shrink-0">02</span>
                            <div>
                                <div class="font-bold text-sm mb-1">Technician assigned</div>
                                <div class="text-gray-400 text-sm leading-relaxed">
                                    A qualified technician is matched to your issue based on required skills.
                                </div>
                            </div>
                        </li>
                        <li class="flex gap-4">
                            <span class="text-[#02f1b4] font-black text-2xl leading-none mono shrink-0">03</span>
                            <div>
                                <div class="font-bold text-sm mb-1">Issue resolved</div>
                                <div class="text-gray-400 text-sm leading-relaxed">
                                    Work is completed within the priority window and you're notified.
                                </div>
                            </div>
                        </li>
                    </ol>
                </div>

                @* Already submitted *@
                <div class="border-2 border-[#041f41] p-8">
                    <div class="flex items-center gap-3 mb-3">
                        <span class="dot" style="background:#041f41"></span>
                        <span class="mono text-xs tracking-[0.25em] text-[#041f41] uppercase">Already submitted?</span>
                    </div>
                    <p class="text-gray-600 text-sm mb-5 leading-relaxed">
                        Track the status of an existing service request using your ticket number.
                    </p>
                    <a asp-controller="Public" asp-action="CheckStatus"
                       class="block text-center border-2 border-[#041f41] text-[#041f41] py-3
                              mono font-black text-xs tracking-widest uppercase
                              hover:bg-[#041f41] hover:text-[#02f1b4] transition">
                        Check Ticket Status →
                    </a>
                </div>

            </div>

        </div>
    </div>
</section>

@* Ticket lifecycle *@
<section class="bg-gray-50 border-t border-gray-200 py-16">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">

        <div class="flex items-center gap-3 mb-10">
            <span class="dot"></span>
            <span class="mono text-xs tracking-[0.25em] text-[#02f1b4] uppercase">Ticket Lifecycle</span>
        </div>

        @* STatus steps implemented as a bordered grid*@
        <div class="grid grid-cols-2 md:grid-cols-5 gap-px bg-gray-200">
            <div class="bg-white px-6 py-6">
                <div class="w-2 h-2 bg-blue-500 mb-3"></div>
                <div class="font-black text-sm text-[#041f41] mb-1">New</div>
                <div class="text-xs text-gray-500 leading-relaxed">Request logged, pending assignment</div>
            </div>
            <div class="bg-white px-6 py-6">
                <div class="w-2 h-2 bg-yellow-400 mb-3"></div>
                <div class="font-black text-sm text-[#041f41] mb-1">Assigned</div>
                <div class="text-xs text-gray-500 leading-relaxed">Technician allocated to the job</div>
            </div>
            <div class="bg-white px-6 py-6">
                <div class="w-2 h-2 bg-purple-500 mb-3"></div>
                <div class="font-black text-sm text-[#041f41] mb-1">In Progress</div>
                <div class="text-xs text-gray-500 leading-relaxed">Active work underway on site</div>
            </div>
            <div class="bg-white px-6 py-6">
                <div class="w-2 h-2 bg-[#02f1b4] mb-3"></div>
                <div class="font-black text-sm text-[#041f41] mb-1">Resolved</div>
                <div class="text-xs text-gray-500 leading-relaxed">Issue fixed, awaiting sign-off</div>
            </div>
            <div class="bg-white px-6 py-6">
                <div class="w-2 h-2 bg-gray-400 mb-3"></div>
                <div class="font-black text-sm text-[#041f41] mb-1">Closed</div>
                <div class="text-xs text-gray-500 leading-relaxed">Verified and archived</div>
            </div>
        </div>

    </div>
</section>
