@{
    ViewData["Title"] = "Access Denied";
    Layout = "~/Views/Shared/_LayoutPublic.cshtml";
}
<style>
    body {
        font-family: 'Exo 2', sans-serif;
    }

    .mono {
        font-family: 'Saira', sans-serif;
    }

    .gruppo {
        font-family: 'Gruppo', sans-serif;
    }
</style>
<div class="min-h-screen bg-gray-50 flex items-center justify-center py-16 px-4">

    <div class="text-center max-w-md">

        @* 403 error*@
        <div class="text-9xl font-black text-[#041f41] leading-none mb-4 gruppo">
            403
        </div>

        @* Divider line *@
        <div class="w-16 h-1 bg-[#02f1b4] mx-auto mb-6"></div>

        <div class="flex items-center justify-center gap-2 mb-3">
            <span class="w-1.5 h-1.5 bg-[#02f1b4] inline-block"></span>
            <span 
                  class="text-[10px] tracking-[0.25em] text-[#02f1b4] uppercase font-bold mono">
                Access Denied
            </span>
        </div>

        <h1 class="text-2xl font-black text-[#041f41] mb-3">
            You don't have permission to view this page.
        </h1>
        <p class="text-gray-500 text-sm mb-8">
            Your account doesn't have the required role to access this area.
            Contact an administrator if you think this is a mistake.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a asp-controller="Home" asp-action="Index"
               class="mono px-6 py-3 bg-[#041f41] tracking-[.15em] text-[#02f1b4] text-xs font-black uppercase
                      border-2 border-[#041f41] hover:bg-[#02f1b4] hover:text-[#041f41] transition">
                ← Back to Home
            </a>
            <a asp-controller="Account" asp-action="Login"
               class="mono tracking-[.15em] px-6 py-3 border-2 border-[#041f41] text-[#041f41] text-xs font-black uppercase
                      hover:bg-[#041f41] hover:text-[#02f1b4] transition">
                Login as Different User
            </a>
        </div>

    </div>
</div>
