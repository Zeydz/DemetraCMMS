<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin - Maintenance System</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Exo+2:ital,wght@0,100..900;1,100..900&family=Gruppo&family=Saira:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/styles.css"/>
    <style>
        body {
            font-family: 'Exo 2', sans-serif;
        }

        .mono {
            font-family: 'Saira', sans-serif;
        }

        .gruppo {
            font-family: 'Gruppo', sans-serif;
        }
    </style>

</head>
<body>
    
    <div class="flex h-screen overflow-hidden">
        
        @*Overlay (shows on phone when open)*@
        <div id="sidebar-overlay" 
             class="fixed inset-0 bg-black/50 z-40 lg:hidden hidden"
             onclick="toggleSidebar()"></div>
        
        @* Left sidebar*@
        <aside id="sidebar" 
               class="w-64 bg-[#041f41] text-white flex flex-col flex-shrink-0 z-50
                      fixed lg:static inset-y-0 left-0 transform -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-in-out">
            
            @* Brand *@
            <div class="px-6 py-5 border-b border-white/10">
                <a asp-controller="Home" asp-action="Index" class="flex items-center gap-2">
                    <span class="gruppo text-xl font-bold text-[#75c6a4] tracking-tight">
                        Demetra
                    </span>
                    <span class="mono text-white/30 text-xs">/ Admin</span>
                </a>
            </div>
            
            @* Nav label*@
            <div class="px-6 pt-6 pb-2">
                <span class="mono text-[10px] tracking-[0.25em] text-[#02f1b4] uppercase font-bold">
                    Navigation
                </span>
            </div>
            
            @* Nav items*@
            <nav class="flex-1 px-3 pb-4 space-y-0.5 overflow-y-auto">
                
                @{
                    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                    Func<string, string> NavClass = (controller) =>
                        currentController == controller
                            ? "flex items-center gap-3 px-4 py-2.5 text-sm font-bold bg-[#02f1b4] text-[#041f41] rounded"
                            : "flex items-center gap-3 px-4 py-2.5 text-sm font-medium text-gray-300 hover:bg-white/10 hover:text-white transition rounded";
                }
                
                <a asp-controller="Dashboard" asp-action="Index" class="@NavClass("Dashboard")">
                    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                    </svg>
                    Dashboard
                </a>
                
                <a asp-controller="Tickets" asp-action="Index" class="@NavClass("Tickets")">
                    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                    </svg>
                    Tickets
                </a>
                
                <a asp-controller="Locations" asp-action="Index" class="@NavClass("Locations")">
                    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    Locations
                </a>
                
                <a asp-controller="Equipment" asp-action="Index" class="@NavClass("Equipment")">
                    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065zM15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    Equipment
                </a>
                
                <a asp-controller="Technicians" asp-action="Index" class="@NavClass("Technicians")">
                    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    Technicians
                </a>
                
                <a asp-controller="Skills" asp-action="Index" class="@NavClass("Skills")">
                    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                    </svg>
                    Skills
                </a>
                
                <a asp-controller="MaintenanceSchedules" asp-action="Index" class="@NavClass("MaintenanceSchedules")">
                    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    Maintenance
                </a>
                
            </nav>
            
            @* User + SignOut*@
            <div class="border-t border-white/10 p-4">
                <div class="flex items-center gap-3 px-2 mb-3">
                    @* Avatar *@
                    <div class="w-8 h-8 bg-[#02f1b4] flex items-center justify-center shrink-0">
                        <span class="mono text-[#041f41] text-xs font-black">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                @User.Identity.Name?.Substring(0, 1).ToUpper()
                            }
                            else
                            {
                                <text>A</text>
                            }
                        </span>
                    </div>
                    <div class="min-w-0">
                        <p class="text-xs font-semibold text-white truncate">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                @User.Identity.Name
                            }
                            else
                            {
                                <text>admin@example.com</text>
                            }
                        </p>
                        <p class="mono text-[10px] text-[#02f1b4] tracking-widest uppercase">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                @if (User.IsInRole("Admin"))
                                {
                                    <text>Administrator</text>
                                }
                                else if (User.IsInRole("Manager"))
                                {
                                    <text>Manager</text>
                                }
                                else if (User.IsInRole("Technician"))
                                {
                                    <text>Technician</text>
                                }
                                else if (User.IsInRole("User"))
                                {
                                    <text>User</text>
                                }
                                else
                                {
                                    <text>No Role</text>
                                }
                            }
                            else
                            {
                                <text>Administrator</text>
                            }
                        </p>
                    </div>
                </div>
                
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit"
                            class="mono tracking-[.15em] w-full flex items-center justify-center gap-2 px-4 py-2.5
                                   border border-white/20 text-gray-400 text-[10px] font-bold uppercase
                                   hover:border-[#02f1b4] hover:text-[#02f1b4] transition cursor-pointer">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                        </svg>
                        Sign Out
                    </button>
                </form>
            </div>
            
        </aside>
        
        @* Main content area*@
        <div class="flex-1 flex flex-col overflow-hidden lg:ml-0">
            
            @* Top bar with hamburger and page title*@
            <header class="bg-white border-b border-gray-200 px-4 lg:px-8 py-4 flex items-center gap-3 shrink-0">
                
                @* Hamburger button (only visible on mobile devices)*@
                <button onclick="toggleSidebar()" 
                        class="lg:hidden p-2 -ml-2 text-[#041f41] hover:bg-gray-100 rounded transition">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                    </svg>
                </button>
                
                <div class="w-1 h-6 bg-[#02f1b4]"></div>
                <h1 class="text-xl font-black text-[#041f41] tracking-tight">
                    @ViewData["Title"]
                </h1>
            </header>
            @* Page content*@
            <main class="flex-1 overflow-y-auto bg-gray-50 p-4 lg:p-8">
                @RenderBody()
            </main>
        </div>
    </div>
    
    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebar-overlay');
            
            // toggle sidebar slidein
            sidebar.classList.toggle('-translate-x-full');
            
            // Toggle the overlay visibility
            overlay.classList.toggle('hidden');
        }
        
        // Close sidebar when clicking a nav link on mobile
        document.addEventListener('DOMContentLoaded', function() {
            const navLinks = document.querySelectorAll('#sidebar nav a');
            navLinks.forEach(link => {
                link.addEventListener('click', function() {
                    // Only close on mobile (screen width < 1024px)
                    if (window.innerWidth < 1024) {
                        toggleSidebar();
                    }
                });
            });
        });
    </script>
    
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
