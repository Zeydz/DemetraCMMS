@model dotnet_projektuppgift.ViewModels.ManageSkillsViewModel

@{
    ViewData["Title"] = "Manage Skills";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="max-w-4xl">

    @* Breadcrumb*@
    <div class="mb-6">
        <a asp-action="Details" asp-route-id="@Model.TechnicianId" class="mono text-xs tracking-widest uppercase text-gray-400 hover:text-[#041f41] transition">
            ← Back to Technician Details
        </a>
    </div>

    @* Page header*@
    <div class="mb-8">
        <div class="flex items-center gap-3 mb-3">
            <span class="w-1.5 h-1.5 bg-[#02f1b4] inline-block"></span>
            <span class="mono text-[10px] tracking-[0.25em] text-[#02f1b4] uppercase font-bold">
                Manage Skills
            </span>
        </div>
        <h2 class="text-2xl font-black text-[#041f41]">@Model.TechnicianName</h2>
        <p class="text-sm text-gray-500 mt-2">Select the skills this technician has. Changes are saved immediately.</p>
    </div>

    @* Content*@
    <div class="bg-white border-2 border-gray-200 p-8">
        <form asp-action="ManageSkills" asp-route-id="@Model.TechnicianId" method="post">

            @if (Model.AvailableSkills.Any())
            {
                <div class="space-y-4">
                    @foreach (var skill in Model.AvailableSkills)
                    {
                        /* Print out skills*/
                        <div class="p-4 border-2 border-gray-200 hover:border-[#02f1b4] transition">
                            <label class="flex items-start gap-4 cursor-pointer">
                                @*Checkbox is checked if skill is assigned to technician, otherwise unchecked. Value is skill id.*@
                                <input type="checkbox"
                                       name="selectedSkills"
                                       value="@skill.SkillId"
                                       @(skill.IsSelected ? "checked" : "")
                                       class="w-5 h-5 mt-0.5 border-2 border-gray-300 text-[#02f1b4] focus:ring-[#02f1b4] focus:ring-offset-0 shrink-0"/>

                                <div class="flex-1">
                                    <div class="font-bold text-sm text-[#041f41] mb-1">@skill.SkillName</div>
                                    <div class="text-xs text-gray-600">@skill.SkillDescription</div>
                                </div>

                                @if (skill.IsSelected)
                                {
                                    <span class="mono inline-block px-2 py-1 text-[10px] font-bold tracking-widest uppercase border bg-green-50 text-green-700 border-green-200 shrink-0">
                                        Assigned
                                    </span>
                                }
                            </label>
                        </div>
                    }
                </div>

                /* Action buttons */
                <div class="flex items-center gap-3 pt-6 mt-6 border-t-2 border-gray-100">
                    <button type="submit"
                            class="cursor-pointer mono tracking-[0.15em] flex items-center gap-2 px-6 py-3 
                                   bg-[#041f41] text-[#02f1b4] text-xs font-black uppercase
                                   border-2 border-[#041f41] hover:bg-[#02f1b4] hover:text-[#041f41] transition">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        Save Changes
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.TechnicianId"
                       class="mono tracking-[0.15em] px-6 py-3 text-xs font-bold uppercase
                              border-2 border-gray-300 text-gray-600
                              hover:border-[#041f41] hover:text-[#041f41] transition">
                        Cancel
                    </a>
                </div>
            }
            else
            {
                /*If there are no skills available, show a message and a link to create the first skill.*/
                <div class="text-center py-12">
                    <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                    </svg>
                    <h3 class="text-lg font-bold text-[#041f41] mb-2">No skills available</h3>
                    <p class="text-sm text-gray-500 mb-6">Create some skills first before assigning them to technicians.</p>
                    <a asp-controller="Skills" asp-action="Create"
                       class="mono tracking-[0.15em] inline-flex items-center gap-2 px-6 py-3 
                              bg-[#041f41] text-[#02f1b4] text-xs font-black uppercase
                              border-2 border-[#041f41] hover:bg-[#02f1b4] hover:text-[#041f41] transition">
                        Create First Skill
                    </a>
                </div>
            }

        </form>
    </div>

</div>
