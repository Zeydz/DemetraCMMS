@using dotnet_projektuppgift.Models.Enums
@model dotnet_projektuppgift.Models.Entities.Technician

@{
    ViewData["Title"] = "Technician Details";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="max-w-4xl">

    @* Breadcrumb *@
    <div class="mb-6">
        <a asp-action="Index"
           class="mono text-xs tracking-widest uppercase text-gray-400 hover:text-[#041f41] transition">
            ← Back to Technicians
        </a>
    </div>

    @* Page header *@
    <div class="mb-8 flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
        <div>
            <div class="flex items-center gap-3 mb-3">
                <span class="w-1.5 h-1.5 bg-[#02f1b4] inline-block"></span>
                <span class="mono text-[10px] tracking-[0.25em] text-[#02f1b4] uppercase font-bold">
                    Technician Details
                </span>
            </div>
            <h2 class="text-2xl sm:text-3xl font-black text-[#041f41]">@Model.Name</h2>
        </div>

        <a asp-action="Edit" asp-route-id="@Model.Id"
           class="mono tracking-[0.15em] flex items-center justify-center gap-2 px-4 py-2.5 text-xs font-bold uppercase border-2 border-[#02f1b4] text-[#02f1b4] hover:bg-[#02f1b4] hover:text-[#041f41] transition w-full sm:w-auto">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
            Edit
        </a>
    </div>

    @* Details card *@
    <div class="bg-white border-2 border-gray-200 p-6 sm:p-8 space-y-6">

        @* Contact Information *@
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">

            <div>
                <div class="mono text-[10px] tracking-widest uppercase text-gray-400 font-bold mb-2">
                    Email
                </div>
                <div class="text-sm text-gray-600">@Model.Email</div>
            </div>

            <div>
                <div class="mono text-[10px] tracking-widest uppercase text-gray-400 font-bold mb-2">
                    Phone Number
                </div>
                <div class="mono text-sm text-gray-600">
                    @(string.IsNullOrEmpty(Model.PhoneNumber) ? "—" : Model.PhoneNumber)
                </div>
            </div>

            <div>
                <div class="mono text-[10px] tracking-widest uppercase text-gray-400 font-bold mb-2">
                    Hire Date
                </div>
                <div class="mono text-sm text-gray-600">
                    @Model.HireDate.ToString("MMMM dd, yyyy")
                </div>
            </div>

            <div>
                <div class="mono text-[10px] tracking-widest uppercase text-gray-400 font-bold mb-2">
                    Status
                </div>
                @if (Model.IsActive)
                {
                    <span
                        class="mono inline-block px-2 py-1 text-[10px] font-bold tracking-widest uppercase border bg-green-50 text-green-700 border-green-200">
                        Active
                    </span>
                }
                else
                {
                    <span
                        class="mono inline-block px-2 py-1 text-[10px] font-bold tracking-widest uppercase border bg-gray-50 text-gray-700 border-gray-200">
                        Inactive
                    </span>
                }
            </div>

        </div>

        @* Metadata *@
        <div class="pt-6 border-t-2 border-gray-100">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">

                <div>
                    <div class="mono text-[10px] tracking-widest uppercase text-gray-400 font-bold mb-2">
                        Created
                    </div>
                    <div class="mono text-sm text-gray-600">
                        @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                    </div>
                </div>

                <div>
                    <div class="mono text-[10px] tracking-widest uppercase text-gray-400 font-bold mb-2">
                        Technician ID
                    </div>
                    <div class="mono text-sm text-gray-600">
                        #@Model.Id
                    </div>
                </div>

            </div>
        </div>

    </div>

    @* Skills *@
    <div class="mt-6 bg-white border-2 border-gray-200">
        <div class="px-4 sm:px-6 py-4 border-b-2 border-gray-200 bg-gray-50">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <svg class="w-5 h-5 text-[#02f1b4]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                    </svg>
                    <span class="mono text-xs tracking-widest uppercase text-gray-600 font-bold">
                    Skills
                </span>
                    <span class="mono text-xs text-gray-500 ml-2">
                    @Model.TechnicianSkills.Count skill@(Model.TechnicianSkills.Count == 1 ? "" : "s")
                </span>
                </div>

                @* Manage Skills button *@
                <a asp-action="ManageSkills" asp-route-id="@Model.Id"
                   class="mono tracking-[0.1em] inline-flex items-center gap-2 px-4 py-2 text-[10px] font-bold uppercase
                      border-2 border-[#02f1b4] text-[#02f1b4]
                      hover:bg-[#02f1b4] hover:text-[#041f41] transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                    </svg>
                    Manage Skills
                </a>
            </div>
        </div>

        @if (Model.TechnicianSkills.Any())
        {
            <div class="divide-y divide-gray-100">
                @foreach (var techSkill in Model.TechnicianSkills)
                {
                    <div class="px-4 sm:px-6 py-4 hover:bg-gray-50 transition">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-3">
                                <div>
                                    <div class="font-bold text-sm text-[#041f41]">@techSkill.Skill.Name</div>
                                    @if (!string.IsNullOrEmpty(techSkill.Skill.Description))
                                    {
                                        <div class="text-xs text-gray-500 mt-1">@techSkill.Skill.Description</div>
                                    }
                                </div>
                            </div>

                            <div class="flex items-center gap-3">
                                <div class="text-xs text-gray-500 hidden sm:block">
                                    <span
                                        class="mono tracking-widest uppercase text-gray-400 font-bold">Assigned:</span>
                                    <span
                                        class="mono ml-2 text-gray-600">@techSkill.AssignedDate.ToString("MMM yyyy")</span>
                                </div>

                                <a asp-controller="Skills" asp-action="Details" asp-route-id="@techSkill.SkillId"
                                   class="mono tracking-[0.1em] px-3 py-1.5 text-[10px] font-bold uppercase
                                      border border-gray-300 text-gray-600
                                      hover:border-[#041f41] hover:text-[#041f41] transition">
                                    View Skill
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="px-6 py-8 text-center text-gray-400 text-sm">
                <p>No skills assigned yet. Click "Manage Skills" to add some.</p>
            </div>
        }
    </div>

   @* Assigned Tickets Section *@
    <div class="mt-6 bg-white border-2 border-gray-200">
        <div class="px-4 sm:px-6 py-4 border-b-2 border-gray-200 bg-gray-50">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <svg class="w-5 h-5 text-[#02f1b4]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                    </svg>
                    <span class="mono text-xs tracking-widest uppercase text-gray-600 font-bold">
                        Assigned Tickets (@Model.AssignedTickets.Count)
                    </span>
                </div>
                <a asp-controller="Tickets" asp-action="Index"
                   class="mono text-[10px] tracking-widest uppercase text-[#02f1b4] hover:text-[#041f41] font-bold transition">
                    View All →
                </a>
            </div>
        </div>

        @* Show tickets if there are any*@
        @if (Model.AssignedTickets != null && Model.AssignedTickets.Any())
        {
            <div class="divide-y divide-gray-100">
                @* Show ten tickets maximum, deschending order*@
                @foreach (var ticket in Model.AssignedTickets.OrderByDescending(t => t.CreatedDate).Take(10))
                {
                    var ticketStatusClass = ticket.Status switch
                    {
                        TicketStatus.New => "bg-gray-50 text-gray-700 border-gray-200",
                        TicketStatus.Assigned => "bg-blue-50 text-blue-700 border-blue-200",
                        TicketStatus.InProgress => "bg-purple-50 text-purple-700 border-purple-200",
                        TicketStatus.Resolved => "bg-green-50 text-green-700 border-green-200",
                        _ => "bg-gray-50 text-gray-700 border-gray-200"
                    };

                    var priorityClass = ticket.Priority switch
                    {
                        TicketPriority.Critical => "bg-red-50 text-red-700 border-red-200",
                        TicketPriority.High => "bg-orange-50 text-orange-700 border-orange-200",
                        TicketPriority.Medium => "bg-yellow-50 text-yellow-700 border-yellow-200",
                        _ => "bg-blue-50 text-blue-700 border-blue-200"
                    };

                    <div class="px-4 sm:px-6 py-4 hover:bg-gray-50 transition">
                        <div class="flex items-start justify-between gap-4">
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2 mb-2">
                                    <span class="mono text-xs text-gray-400">#@ticket.Id</span>
                                    <span class="mono inline-block px-2 py-0.5 text-[9px] font-bold tracking-widest uppercase border @priorityClass">
                                        @ticket.Priority
                                    </span>
                                    <span class="mono inline-block px-2 py-0.5 text-[9px] font-bold tracking-widest uppercase border @ticketStatusClass">
                                        @ticket.Status
                                    </span>
                                </div>
                                <h4 class="font-semibold text-sm text-[#041f41] mb-1">
                                    @ticket.Title
                                </h4>
                                <div class="flex flex-wrap items-center gap-3 text-xs text-gray-500">
                                    <div class="flex items-center gap-1">
                                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                                        </svg>
                                        <span>@ticket.Equipment?.Name</span>
                                    </div>
                                    <div class="flex items-center gap-1">
                                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                                        </svg>
                                        <span>@ticket.Equipment?.Location?.Name</span>
                                    </div>
                                    <div class="flex items-center gap-1">
                                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                        </svg>
                                        <span class="mono">@ticket.CreatedDate.ToString("MMM dd, HH:mm")</span>
                                    </div>
                                    @* Show if ticket is overdue*@
                                    @if (ticket.DueDate < DateTime.UtcNow && ticket.Status != TicketStatus.Resolved && ticket.Status != TicketStatus.Closed)
                                    {
                                        <div class="flex items-center gap-1 text-red-600 font-semibold">
                                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                            </svg>
                                            <span>Overdue</span>
                                        </div>
                                    }
                                </div>
                            </div>
                            <a asp-controller="Tickets" asp-action="Details" asp-route-id="@ticket.Id"
                               class="mono tracking-[0.1em] px-3 py-1.5 text-[10px] font-bold uppercase border border-gray-300 text-gray-600 hover:border-[#041f41] hover:text-[#041f41] transition shrink-0">
                                View
                            </a>
                        </div>
                    </div>
                }
            </div>
            /* If more than 10 tickets exist, show View All Tickets button*/
            @if (Model.AssignedTickets.Count > 10)
            {
                <div class="px-4 sm:px-6 py-3 bg-gray-50 border-t-2 border-gray-200 text-center">
                    <a asp-controller="Tickets" asp-action="Index"
                       class="mono text-xs tracking-widest uppercase text-[#02f1b4] hover:text-[#041f41] font-bold transition">
                        View All @Model.AssignedTickets.Count Tickets →
                    </a>
                </div>
            }
        }
        else
        {
            <div class="px-4 sm:px-6 py-8 text-center">
                <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                </svg>
                <p class="text-gray-400 text-sm">No tickets assigned yet</p>
            </div>
        }
    </div>

    @* Bottom actions *@
    <div class="mt-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <a asp-action="Index"
           class="mono tracking-[0.15em] px-4 py-2.5 text-xs font-bold uppercase text-center border-2 border-gray-300 text-gray-600 hover:border-[#041f41] hover:text-[#041f41] transition w-full sm:w-auto">
            ← Back to List
        </a>

        <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
              onsubmit="return confirm('Are you sure you want to delete @Model.Name? This action cannot be undone.');"
              class="w-full sm:w-auto">
            <button type="submit"
                    class="mono tracking-[0.15em] flex items-center justify-center gap-2 px-4 py-2.5 text-xs font-bold uppercase border-2 border-red-300 text-red-600 hover:bg-red-600 hover:text-white hover:border-red-600 transition w-full">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
                Delete Technician
            </button>
        </form>
    </div>

</div>
