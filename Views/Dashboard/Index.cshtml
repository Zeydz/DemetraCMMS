@model dotnet_projektuppgift.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="space-y-6">

    @* Welcome message *@
    <div>
        <div class="flex items-center gap-3 mb-3">
            <span class="w-1.5 h-1.5 bg-[#02f1b4] inline-block"></span>
            <span class="mono text-[10px] tracking-[0.25em] text-[#02f1b4] uppercase font-bold">
                Overview
            </span>
        </div>
        <h1 class="text-3xl font-black text-[#041f41]">Welcome back, @ViewData["UserName"]</h1>
        <p class="text-sm text-gray-500 mt-2">Here's what's happening with your maintenance system today.</p>
    </div>

    @* Ticket Statistics - Main Cards *@
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        
        @* Total Tickets *@
        <div class="bg-white border-2 border-[#02f1b4] p-6">
            <div class="flex items-center justify-between mb-4">
                <div class="mono text-xs tracking-widest uppercase text-gray-400 font-bold">
                    Total Tickets
                </div>
                <svg class="w-6 h-6 text-[#02f1b4]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
            </div>
            <div class="text-4xl font-black text-[#041f41]">@Model.TotalTickets</div>
            <a asp-controller="Tickets" asp-action="Index" class="text-xs text-gray-500 hover:text-[#02f1b4] transition mt-2 inline-block">
                View all tickets →
            </a>
        </div>

        @* New tickets *@
        <div class="bg-white border-2 border-gray-200 p-6 ">
            <div class="flex items-center justify-between mb-4">
                <div class="mono text-xs tracking-widest uppercase text-gray-400 font-bold">
                    New Tickets
                </div>
                <div class="w-3 h-3 bg-gray-500"></div>
            </div>
            <div class="text-4xl font-black text-[#041f41]">@Model.NewTickets</div>
            <div class="text-xs text-gray-500 mt-2">Awaiting assignment</div>
        </div>

        @* In progress *@
        <div class="bg-white border-2 border-purple-500 p-6">
            <div class="flex items-center justify-between mb-4">
                <div class="mono text-xs tracking-widest uppercase text-gray-400 font-bold">
                    In Progress
                </div>
                <div class="w-3 h-3 bg-purple-500"></div>
            </div>
            <div class="text-4xl font-black text-[#041f41]">@Model.InProgressTickets</div>
            <div class="text-xs text-gray-500 mt-2">Active work</div>
        </div>

        @* Overdue tickets *@
        <div class="bg-white border-2 border-red-500 p-6">
            <div class="flex items-center justify-between mb-4">
                <div class="mono text-xs tracking-widest uppercase text-gray-400 font-bold">
                    Overdue
                </div>
                <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
            <div class="text-4xl font-black text-red-600">@Model.OverdueTickets</div>
            <div class="text-xs text-red-600 mt-2">
                @(Model.OverdueTickets > 0 ? "Needs attention!" : "All on track")
            </div>
        </div>

    </div>

    @* Two column layout using grid *@
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        @* Left: Status & priority breakdown *@
        <div class="lg:col-span-2 space-y-6">

            @* Status breakdown *@
            <div class="bg-white border-2 border-gray-200 p-6">
                <h3 class="mono text-xs tracking-widest uppercase text-gray-400 font-bold mb-4">
                    Ticket Status Breakdown
                </h3>
                @* New tickets *@
                <div class="space-y-3">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <div class="w-2 h-2 bg-gray-500"></div>
                            <span class="text-sm text-gray-700">New</span>
                        </div>
                        <span class="mono text-sm font-bold text-[#041f41]">@Model.NewTickets</span>
                    </div>
                    @* Assigned tickets*@
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <div class="w-2 h-2 bg-blue-500"></div>
                            <span class="text-sm text-gray-700">Assigned</span>
                        </div>
                        <span class="mono text-sm font-bold text-[#041f41]">@Model.AssignedTickets</span>
                    </div>
                    @* In progress*@
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <div class="w-2 h-2 bg-purple-500"></div>
                            <span class="text-sm text-gray-700">In Progress</span>
                        </div>
                        <span class="mono text-sm font-bold text-[#041f41]">@Model.InProgressTickets</span>
                    </div>
                    @* Resolved *@
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <div class="w-2 h-2 bg-green-500"></div>
                            <span class="text-sm text-gray-700">Resolved</span>
                        </div>
                        <span class="mono text-sm font-bold text-[#041f41]">@Model.ResolvedTickets</span>
                    </div>
                    @* Closed tickets *@
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <div class="w-2 h-2 bg-gray-400"></div>
                            <span class="text-sm text-gray-700">Closed</span>
                        </div>
                        <span class="mono text-sm font-bold text-[#041f41]">@Model.ClosedTickets</span>
                    </div>
                </div>
            </div>

            @* Priority Breakdown *@
            <div class="bg-white border-2 border-gray-200 p-6">
                <h3 class="mono text-xs tracking-widest uppercase text-gray-400 font-bold mb-4">
                    Priority Breakdown
                </h3>
                @* Critical *@
                <div class="grid grid-cols-2 gap-4">
                    <div class="border-2 border-red-200 bg-red-50 p-4">
                        <div class="text-2xl font-black text-red-700">@Model.CriticalTickets</div>
                        <div class="mono text-xs tracking-widest uppercase text-red-600 font-bold">Critical</div>
                    </div>
                    @* High*@
                    <div class="border-2 border-orange-200 bg-orange-50 p-4">
                        <div class="text-2xl font-black text-orange-700">@Model.HighTickets</div>
                        <div class="mono text-xs tracking-widest uppercase text-orange-600 font-bold">High</div>
                    </div>
                    @* Medium *@
                    <div class="border-2 border-yellow-200 bg-yellow-50 p-4">
                        <div class="text-2xl font-black text-yellow-700">@Model.MediumTickets</div>
                        <div class="mono text-xs tracking-widest uppercase text-yellow-600 font-bold">Medium</div>
                    </div>
                    @* Low*@
                    <div class="border-2 border-blue-200 bg-blue-50 p-4">
                        <div class="text-2xl font-black text-blue-700">@Model.LowTickets</div>
                        <div class="mono text-xs tracking-widest uppercase text-blue-600 font-bold">Low</div>
                    </div>
                </div>
            </div>

        </div>

        @* Right: System Stats & Recent Activity *@
        <div class="space-y-6">

            @* Equipment Stats *@
            <div class="bg-white border-2 border-gray-200 p-6">
                <h3 class="mono text-xs tracking-widest uppercase text-gray-400 font-bold mb-4">
                    Equipment
                </h3>
                @* Total equipment *@
                <div class="space-y-3">
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-gray-600">Total</span>
                        <span class="font-bold text-[#041f41]">@Model.TotalEquipment</span>
                    </div>
                    @* Operational equipment*@
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-gray-600">Operational</span>
                        <span class="font-bold text-green-600">@Model.OperationalEquipment</span>
                    </div>
                    @* Under Maintenance equiptment*@
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-gray-600">Maintenance</span>
                        <span class="font-bold text-yellow-600">@Model.EquipmentUnderMaintenance</span>
                    </div>
                    @* Out of service equipment*@
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-gray-600">Out of Service</span>
                        <span class="font-bold text-red-600">@Model.OutOfServiceEquipment</span>
                    </div>
                </div>
                <a asp-controller="Equipment" asp-action="Index" class="block text-center mt-4 pt-4 border-t border-gray-200 text-xs text-gray-500 hover:text-[#02f1b4] transition">
                    Manage Equipment →
                </a>
            </div>

            @* Technicians Stats *@
            <div class="bg-white border-2 border-gray-200 p-6">
                <h3 class="mono text-xs tracking-widest uppercase text-gray-400 font-bold mb-4">
                    Technicians
                </h3>
                @* Total technicians *@
                <div class="space-y-3">
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-gray-600">Total</span>
                        <span class="font-bold text-[#041f41]">@Model.TotalTechnicians</span>
                    </div>
                    @* Active technicians *@
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-gray-600">Active</span>
                        <span class="font-bold text-green-600">@Model.ActiveTechnicians</span>
                    </div>
                    @* Inactive technicians*@
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-gray-600">Inactive</span>
                        <span class="font-bold text-gray-500">@Model.InactiveTechnicians</span>
                    </div>
                </div>
                <a asp-controller="Technicians" asp-action="Index" class="block text-center mt-4 pt-4 border-t border-gray-200 text-xs text-gray-500 hover:text-[#02f1b4] transition">
                    Manage Technicians →
                </a>
            </div>
        </div>

    </div>

    @* Recent Tickets *@
    @if (Model.RecentTickets.Any())
    {
        <div class="bg-white border-2 border-gray-200">
            <div class="px-6 py-4 border-b-2 border-gray-200 bg-gray-50">
                <h3 class="mono text-xs tracking-widest uppercase text-gray-400 font-bold">
                    Recent Tickets
                </h3>
            </div>
            <div class="divide-y divide-gray-100">
                @foreach (var ticket in Model.RecentTickets)
                {
                    var statusClass = ticket.Status switch
                    {
                        "New" => "bg-gray-50 text-gray-700 border-gray-200",
                        "Assigned" => "bg-blue-50 text-blue-700 border-blue-200",
                        "InProgress" => "bg-purple-50 text-purple-700 border-purple-200",
                        "Resolved" => "bg-green-50 text-green-700 border-green-200",
                        _ => "bg-gray-50 text-gray-700 border-gray-200"
                    };

                    var priorityClass = ticket.Priority switch
                    {
                        "Critical" => "bg-red-50 text-red-700 border-red-200",
                        "High" => "bg-orange-50 text-orange-700 border-orange-200",
                        "Medium" => "bg-yellow-50 text-yellow-700 border-yellow-200",
                        _ => "bg-blue-50 text-blue-700 border-blue-200"
                    };

                    <div class="px-6 py-4 hover:bg-gray-50 transition">
                        <div class="flex items-center justify-between">
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="mono text-xs text-gray-400">#@ticket.Id</span>
                                    <span class="mono inline-block px-2 py-0.5 text-[9px] font-bold tracking-widest uppercase border @priorityClass">
                                        @ticket.Priority
                                    </span>
                                    <span class="mono inline-block px-2 py-0.5 text-[9px] font-bold tracking-widest uppercase border @statusClass">
                                        @ticket.Status
                                    </span>
                                </div>
                                <div class="font-semibold text-sm text-[#041f41] truncate">@ticket.Title</div>
                                <div class="text-xs text-gray-500 mono">@ticket.CreatedDate.ToString("MMM dd, HH:mm")</div>
                            </div>
                            <a asp-controller="Tickets" asp-action="Details" asp-route-id="@ticket.Id"
                               class="mono tracking-[0.1em] px-3 py-1.5 text-[10px] font-bold uppercase
                                      border border-gray-300 text-gray-600
                                      hover:border-[#041f41] hover:text-[#041f41] transition ml-4">
                                View
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

</div>
