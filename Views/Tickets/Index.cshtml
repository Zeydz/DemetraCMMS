@using dotnet_projektuppgift.Models.Enums
@model IEnumerable<dotnet_projektuppgift.Models.Entities.Ticket>

@{
    ViewData["Title"] = "Tickets";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="space-y-6">

    @* Success/Error messages *@
    @if (TempData["Success"] != null)
    {
        <div class="bg-green-50 border-2 border-green-200 p-4">
            <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <p class="text-sm font-semibold text-green-800">@TempData["Success"]</p>
            </div>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="bg-red-50 border-2 border-red-200 p-4">
            <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-red-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
                <p class="text-sm font-semibold text-red-800">@TempData["Error"]</p>
            </div>
        </div>
    }

    @* Page header *@
    <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
            <span class="w-1.5 h-1.5 bg-[#02f1b4] inline-block"></span>
            <span class="mono text-[10px] tracking-[0.25em] text-[#02f1b4] uppercase font-bold">
                All Tickets
            </span>
        </div>
        <a asp-action="Create"
           class="mono tracking-[0.15em] flex items-center gap-2 px-6 py-3 
                  bg-[#041f41] text-[#02f1b4] text-xs font-black uppercase
                  border-2 border-[#041f41] hover:bg-[#02f1b4] hover:text-[#041f41] transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
            </svg>
            Create Ticket
        </a>
    </div>

    @* Tickets list *@
    <div class="bg-white border-2 border-gray-200">
        @if (Model.Any())
        {
            <div class="divide-y divide-gray-100">
                @foreach (var ticket in Model)
                {
                    var priorityClass = ticket.Priority switch
                    {
                        TicketPriority.Critical => "bg-red-50 text-red-700 border-red-200",
                        TicketPriority.High => "bg-orange-50 text-orange-700 border-orange-200",
                        TicketPriority.Medium => "bg-yellow-50 text-yellow-700 border-yellow-200",
                        _ => "bg-blue-50 text-blue-700 border-blue-200"
                    };

                    var statusClass = ticket.Status switch
                    {
                        TicketStatus.New => "bg-gray-50 text-gray-700 border-gray-200",
                        TicketStatus.Assigned => "bg-blue-50 text-blue-700 border-blue-200",
                        TicketStatus.InProgress => "bg-purple-50 text-purple-700 border-purple-200",
                        TicketStatus.Resolved => "bg-green-50 text-green-700 border-green-200",
                        _ => "bg-gray-50 text-gray-700 border-gray-200"
                    };

                    <div class="px-6 py-4 hover:bg-gray-50 transition">
                        <div class="flex items-start justify-between gap-4">
                            <div class="flex-1 min-w-0">
                                @* Equipment priority*@
                                <div class="flex items-center gap-2 mb-2">
                                    <span class="mono text-xs text-gray-400">#@ticket.Id</span>
                                    <span class="mono inline-block px-2 py-1 text-[10px] font-bold tracking-widest uppercase border @priorityClass">
                                        @ticket.Priority
                                    </span>
                                    @* Equipment status*@
                                    <span class="mono inline-block px-2 py-1 text-[10px] font-bold tracking-widest uppercase border @statusClass">
                                        @ticket.Status
                                    </span>
                                </div>

                                <h3 class="font-bold text-[#041f41] mb-1">@ticket.Title</h3>

                                @* Equipment name*@
                                <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-gray-600">
                                    <div class="flex items-center gap-1">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                                        </svg>
                                        <span>@ticket.Equipment.Name</span>
                                    </div>

                                    @* Assigned to *@
                                    @if (ticket.AssignedTo != null)
                                    {
                                        <div class="flex items-center gap-1">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                            </svg>
                                            <span>@ticket.AssignedTo.User.FullName</span>
                                        </div>
                                    }

                                    @* Due date *@
                                    <div class="flex items-center gap-1">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                        </svg>
                                        <span class="mono">Due: @ticket.DueDate.ToString("MMM dd")</span>
                                    </div>
                                </div>
                            </div>
                            
                            @* Buttons *@
                            <div class="flex items-center gap-2 shrink-0">
                                <a asp-action="Details" asp-route-id="@ticket.Id"
                                   class="mono tracking-[0.1em] px-3 py-1.5 text-[10px] font-bold uppercase
                                          border border-gray-300 text-gray-600
                                          hover:border-[#041f41] hover:text-[#041f41] transition">
                                    View
                                </a>
                                <a asp-action="Edit" asp-route-id="@ticket.Id"
                                   class="mono tracking-[0.1em] px-3 py-1.5 text-[10px] font-bold uppercase
                                          border border-[#02f1b4] text-[#02f1b4]
                                          hover:bg-[#02f1b4] hover:text-[#041f41] transition">
                                    Edit
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            /* Create first tickets if there are no tickets */
            <div class="px-6 py-16 text-center">
                <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                </svg>
                <h3 class="text-lg font-bold text-[#041f41] mb-2">No tickets yet</h3>
                <p class="text-sm text-gray-500 mb-6">Create your first maintenance ticket.</p>
                <a asp-action="Create"
                   class="mono tracking-[0.15em] inline-flex items-center gap-2 px-6 py-3 
                          bg-[#041f41] text-[#02f1b4] text-xs font-black uppercase
                          border-2 border-[#041f41] hover:bg-[#02f1b4] hover:text-[#041f41] transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
                    </svg>
                    Create First Ticket
                </a>
            </div>
        }
    </div>

    @* Summary *@
    <div class="text-sm text-gray-500">
        Showing <span class="font-semibold text-[#041f41]">@Model.Count()</span>
        ticket@(Model.Count() == 1 ? "" : "s")
    </div>

</div>
