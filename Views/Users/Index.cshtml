@model IEnumerable<dotnet_projektuppgift.ViewModels.UserIndexViewModel>

@{
    ViewData["Title"] = "Users";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="space-y-6">

    @* Success/Error messages *@
    @if (TempData["Success"] != null)
    {
        <div class="bg-green-50 border-2 border-green-200 p-4">
            <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <p class="text-sm font-semibold text-green-800">@TempData["Success"]</p>
            </div>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="bg-red-50 border-2 border-red-200 p-4">
            <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-red-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
                <p class="text-sm font-semibold text-red-800">@TempData["Error"]</p>
            </div>
        </div>
    }

    @* Page header *@
    <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
            <span class="w-1.5 h-1.5 bg-[#02f1b4] inline-block"></span>
            <span class="mono text-[10px] tracking-[0.25em] text-[#02f1b4] uppercase font-bold">
                All Users
            </span>
        </div>
        <a asp-action="Create"
           class="mono tracking-[0.15em] flex items-center gap-2 px-6 py-3 
                  bg-[#041f41] text-[#02f1b4] text-xs font-black uppercase
                  border-2 border-[#041f41] hover:bg-[#02f1b4] hover:text-[#041f41] transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
            </svg>
            Add User
        </a>
    </div>

    @* Users table *@
    <div class="bg-white border-2 border-gray-200">

        @if (Model.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50 border-b-2 border-gray-200">
                        <tr>
                            <th class="mono text-left px-6 py-4 text-[10px] font-bold tracking-widest uppercase text-gray-600">
                                User
                            </th>
                            <th class="mono text-left px-6 py-4 text-[10px] font-bold tracking-widest uppercase text-gray-600">
                                Email
                            </th>
                            <th class="mono text-left px-6 py-4 text-[10px] font-bold tracking-widest uppercase text-gray-600">
                                Phone
                            </th>
                            <th class="mono text-left px-6 py-4 text-[10px] font-bold tracking-widest uppercase text-gray-600">
                                Role
                            </th>
                            <th class="mono text-left px-6 py-4 text-[10px] font-bold tracking-widest uppercase text-gray-600">
                                Status
                            </th>
                            <th class="mono text-right px-6 py-4 text-[10px] font-bold tracking-widest uppercase text-gray-600">
                                Actions
                            </th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-gray-50 transition">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="font-bold text-sm text-[#041f41]">@item.FullName</div>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="text-sm text-gray-600">@item.Email</div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="mono text-xs text-gray-600">
                                        @(string.IsNullOrEmpty(item.PhoneNumber) ? "—" : item.PhoneNumber)
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    @if (item.Roles.Any())
                                    {
                                        @foreach (var role in item.Roles)
                                        {
                                            var roleClass = role switch
                                            {
                                                "Admin" => "bg-purple-50 text-purple-700 border-purple-200",
                                                "Manager" => "bg-blue-50 text-blue-700 border-blue-200",
                                                "Technician" => "bg-green-50 text-green-700 border-green-200",
                                                _ => "bg-gray-50 text-gray-700 border-gray-200"
                                            };
                                            <span class="mono inline-block px-2 py-1 text-[10px] font-bold tracking-widest uppercase border @roleClass mr-1">
                                                @role
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-xs text-gray-400">No role</span>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    @if (item.EmailConfirmed)
                                    {
                                        <span class="mono inline-block px-2 py-1 text-[10px] font-bold tracking-widest uppercase border bg-green-50 text-green-700 border-green-200">
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="mono inline-block px-2 py-1 text-[10px] font-bold tracking-widest uppercase border bg-yellow-50 text-yellow-700 border-yellow-200">
                                            Pending
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center justify-end gap-2">
                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="mono tracking-[0.1em] px-3 py-1.5 text-[10px] font-bold uppercase
                                                  border border-gray-300 text-gray-600
                                                  hover:border-[#041f41] hover:text-[#041f41] transition"
                                           title="View details">
                                            View
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="mono tracking-[0.1em] px-3 py-1.5 text-[10px] font-bold uppercase
                                                  border border-[#02f1b4] text-[#02f1b4]
                                                  hover:bg-[#02f1b4] hover:text-[#041f41] transition"
                                           title="Edit user">
                                            Edit
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                              onsubmit="return confirm('Are you sure you want to delete @item.FullName?');"
                                              class="inline">
                                            <button type="submit"
                                                    class="cursor-pointer mono tracking-[0.1em] px-3 py-1.5 text-[10px] font-bold uppercase
                                                           border border-red-300 text-red-600
                                                           hover:bg-red-600 hover:text-white hover:border-red-600 transition"
                                                    title="Delete user">
                                                Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="px-6 py-16 text-center">
                <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                </svg>
                <h3 class="text-lg font-bold text-[#041f41] mb-2">No users found</h3>
                <p class="text-sm text-gray-500">This shouldn't happen - at least the admin should exist!</p>
            </div>
        }

    </div>

    @* Summary count *@
    <div class="flex items-center justify-between text-sm text-gray-500">
        <div>
            Showing <span class="font-semibold text-[#041f41]">@Model.Count()</span>
            user@(Model.Count() == 1 ? "" : "s")
        </div>
    </div>

</div>
