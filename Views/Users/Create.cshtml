@model dotnet_projektuppgift.ViewModels.CreateUserViewModel

@{
    ViewData["Title"] = "Create User";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="max-w-2xl">

    @* Breadcrumb *@
    <div class="mb-6">
        <a asp-action="Index" class="mono text-xs tracking-widest uppercase text-gray-400 hover:text-[#041f41] transition">
            ← Back to Users
        </a>
    </div>

    @* Page header*@
    <div class="mb-8">
        <div class="flex items-center gap-3 mb-3">
            <span class="w-1.5 h-1.5 bg-[#02f1b4] inline-block"></span>
            <span class="mono text-[10px] tracking-[0.25em] text-[#02f1b4] uppercase font-bold">
                New User
            </span>
        </div>
        <h2 class="text-2xl font-black text-[#041f41]">Create User Account</h2>
        <p class="text-sm text-gray-500 mt-2">Add a new user to the system.</p>
    </div>

    @* Content *@
    <div class="bg-white border-2 border-gray-200 p-8">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="mb-6 bg-red-50 border-2 border-red-200 p-4 text-sm text-red-800"></div>

            @* Full name*@
            <div class="mb-6">
                <label asp-for="FullName" class="mono block text-xs font-bold text-[#041f41] tracking-widest uppercase mb-2">
                    Full Name *
                </label>
                <input asp-for="FullName" 
                       class="w-full px-4 py-3 border-2 border-gray-200 bg-gray-50 text-[#041f41] font-medium
                              focus:outline-none focus:border-[#02f1b4] focus:bg-white transition"
                       placeholder="e.g., John Smith" />
                <span asp-validation-for="FullName" class="text-xs text-red-600 mt-1 block"></span>
            </div>

            @* Email address*@
            <div class="mb-6">
                <label asp-for="Email" class="mono block text-xs font-bold text-[#041f41] tracking-widest uppercase mb-2">
                    Email Address *
                </label>
                <input asp-for="Email" type="email"
                       class="w-full px-4 py-3 border-2 border-gray-200 bg-gray-50 text-[#041f41] font-medium
                              focus:outline-none focus:border-[#02f1b4] focus:bg-white transition"
                       placeholder="e.g., john.smith@example.com" />
                <span asp-validation-for="Email" class="text-xs text-red-600 mt-1 block"></span>
            </div>

            @* Phone number*@
            <div class="mb-6">
                <label asp-for="PhoneNumber" class="mono block text-xs font-bold text-[#041f41] tracking-widest uppercase mb-2">
                    Phone Number <span class="text-gray-400 font-normal">(Optional)</span>
                </label>
                <input asp-for="PhoneNumber" type="tel"
                       class="w-full px-4 py-3 border-2 border-gray-200 bg-gray-50 text-[#041f41] font-medium
                              focus:outline-none focus:border-[#02f1b4] focus:bg-white transition"
                       placeholder="e.g., 555-0123" />
                <span asp-validation-for="PhoneNumber" class="text-xs text-red-600 mt-1 block"></span>
            </div>

            @* Role *@
            <div class="mb-6">
                <label asp-for="Role" class="mono block text-xs font-bold text-[#041f41] tracking-widest uppercase mb-2">
                    Role *
                </label>
                
                <select asp-for="Role" id="roleSelect" asp-items="@(ViewData["Roles"] as SelectList)"
                        class="w-full px-4 py-3 border-2 border-gray-200 bg-gray-50 text-[#041f41] font-medium
               focus:outline-none focus:border-[#02f1b4] focus:bg-white transition">
                    <option value="">Select a role...</option>
                </select>
                
                <span asp-validation-for="Role" class="text-xs text-red-600 mt-1 block"></span>
            </div>
            
            @* Technician-specific fields (shown only when Technician role is selected) *@
            <div id="technicianFields" style="display: none;">
                <div class="mb-6 p-4 bg-blue-50 border-2 border-blue-200">
                    <div class="flex items-start gap-2 mb-4">
                        <svg class="w-5 h-5 text-blue-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        <div class="text-sm text-blue-800">
                            <strong class="font-bold">Technician Role Selected</strong>
                            <p class="mt-1">Additional fields are required to create the technician profile.</p>
                        </div>
                    </div>

                    @* Hire date*@
                    <div class="mb-4">
                        <label asp-for="HireDate" class="mono block text-xs font-bold text-[#041f41] tracking-widest uppercase mb-2">
                            Hire Date *
                        </label>
                        <input asp-for="HireDate" type="date"
                               class="w-full px-4 py-3 border-2 border-gray-200 bg-gray-50 text-[#041f41] font-medium
                                      focus:outline-none focus:border-[#02f1b4] focus:bg-white transition" />
                        <span asp-validation-for="HireDate" class="text-xs text-red-600 mt-1 block"></span>
                    </div>

                    @* Status *@
                    <div>
                        <label class="mono block text-xs font-bold text-[#041f41] tracking-widest uppercase mb-3">
                            Status
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer">
                            <input asp-for="IsActive" type="checkbox" checked
                                   class="w-5 h-5 border-2 border-gray-300 text-[#02f1b4] focus:ring-[#02f1b4] focus:ring-offset-0" />
                            <span class="text-sm text-gray-700">
                                Active (technician is currently employed)
                            </span>
                        </label>
                        <span asp-validation-for="IsActive" class="text-xs text-red-600 mt-1 block"></span>
                    </div>
                </div>
            </div>
            @* Password*@

            <div class="mb-6">
                <label asp-for="Password" class="mono block text-xs font-bold text-[#041f41] tracking-widest uppercase mb-2">
                    Password *
                </label>
                <input asp-for="Password" type="password"
                       class="w-full px-4 py-3 border-2 border-gray-200 bg-gray-50 text-[#041f41] font-medium
                              focus:outline-none focus:border-[#02f1b4] focus:bg-white transition"
                       placeholder="Minimum 6 characters" />
                <span asp-validation-for="Password" class="text-xs text-red-600 mt-1 block"></span>
            </div>
            @* Confirm password*@

            <div class="mb-6">
                <label asp-for="ConfirmPassword" class="mono block text-xs font-bold text-[#041f41] tracking-widest uppercase mb-2">
                    Confirm Password *
                </label>
                <input asp-for="ConfirmPassword" type="password"
                       class="w-full px-4 py-3 border-2 border-gray-200 bg-gray-50 text-[#041f41] font-medium
                              focus:outline-none focus:border-[#02f1b4] focus:bg-white transition"
                       placeholder="Re-enter password" />
                <span asp-validation-for="ConfirmPassword" class="text-xs text-red-600 mt-1 block"></span>
            </div>

            @* Action buttons *@
            <div class="flex items-center gap-3 pt-4 border-t-2 border-gray-100">
                <button type="submit"
                        class="cursor-pointer mono tracking-[0.15em] flex items-center gap-2 px-6 py-3 
                               bg-[#041f41] text-[#02f1b4] text-xs font-black uppercase
                               border-2 border-[#041f41] hover:bg-[#02f1b4] hover:text-[#041f41] transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    Create User
                </button>
                <a asp-action="Index"
                   class="mono tracking-[0.15em] px-6 py-3 text-xs font-bold uppercase
                          border-2 border-gray-300 text-gray-600
                          hover:border-[#041f41] hover:text-[#041f41] transition">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        @*Show/hide technician fields based on role selection*@
        document.getElementById('roleSelect').addEventListener('change', function() {
            var techFields = document.getElementById('technicianFields');
            if (this.value === 'Technician') {
                techFields.style.display = 'block';
            } else {
                techFields.style.display = 'none';
            }
        });

        @*Check on page load (in case of validation error)*@
        window.addEventListener('DOMContentLoaded', function() {
            var roleSelect = document.getElementById('roleSelect');
            var techFields = document.getElementById('technicianFields');
            if (roleSelect.value === 'Technician') {
                techFields.style.display = 'block';
            }
        });
    </script>
}
