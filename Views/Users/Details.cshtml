@model dotnet_projektuppgift.ViewModels.UserDetailsViewModel

@{
    ViewData["Title"] = "User Details";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="max-w-4xl">

    @* Breadcrumb *@
    <div class="mb-6">
        <a asp-action="Index" class="mono text-xs tracking-widest uppercase text-gray-400 hover:text-[#041f41] transition">
            ← Back to Users
        </a>
    </div>

    @* Page header *@
    <div class="mb-8 flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
        <div>
            <div class="flex items-center gap-3 mb-3">
                <span class="w-1.5 h-1.5 bg-[#02f1b4] inline-block"></span>
                <span class="mono text-[10px] tracking-[0.25em] text-[#02f1b4] uppercase font-bold">
                    User Details
                </span>
            </div>
            <h2 class="text-2xl sm:text-3xl font-black text-[#041f41]">@Model.FullName</h2>
        </div>
        
        <a asp-action="Edit" asp-route-id="@Model.Id"
           class="mono tracking-[0.15em] flex items-center justify-center gap-2 px-4 py-2.5 text-xs font-bold uppercase border-2 border-[#02f1b4] text-[#02f1b4] hover:bg-[#02f1b4] hover:text-[#041f41] transition w-full sm:w-auto">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
            Edit
        </a>
    </div>

    @* Content *@
    <div class="bg-white border-2 border-gray-200 p-6 sm:p-8 space-y-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            @* Email *@
            <div>
                <div class="mono text-[10px] tracking-widest uppercase text-gray-400 font-bold mb-2">
                    Email
                </div>
                <div class="text-sm text-gray-600">@Model.Email</div>
            </div>

            <div>
                @* Phone number *@
                <div class="mono text-[10px] tracking-widest uppercase text-gray-400 font-bold mb-2">
                    Phone Number
                </div>
                <div class="mono text-sm text-gray-600">
                    @(string.IsNullOrEmpty(Model.PhoneNumber) ? "—" : Model.PhoneNumber)
                </div>
            </div>

            <div>
                @* Role (change apperance depending on what role)*@
                <div class="mono text-[10px] tracking-widest uppercase text-gray-400 font-bold mb-2">
                    Role
                </div>
                <div class="flex flex-wrap gap-2">
                    @if (Model.Roles.Any())
                    {
                        @foreach (var role in Model.Roles)
                        {
                            var roleClass = role switch
                            {
                                "Admin" => "bg-purple-50 text-purple-700 border-purple-200",
                                "Manager" => "bg-blue-50 text-blue-700 border-blue-200",
                                "Technician" => "bg-green-50 text-green-700 border-green-200",
                                _ => "bg-gray-50 text-gray-700 border-gray-200"
                            };
                            <span class="mono inline-block px-2 py-1 text-[10px] font-bold tracking-widest uppercase border @roleClass">
                                @role
                            </span>
                        }
                    }
                    else
                    {
                        <span class="text-sm text-gray-400">No role assigned</span>
                    }
                </div>
            </div>

            <div>
                @* Account status (if email has been confirmed)*@
                <div class="mono text-[10px] tracking-widest uppercase text-gray-400 font-bold mb-2">
                    Account Status
                </div>
                @if (Model.EmailConfirmed)
                {
                    <span class="mono inline-block px-2 py-1 text-[10px] font-bold tracking-widest uppercase border bg-green-50 text-green-700 border-green-200">
                        Active
                    </span>
                }
                else
                {
                    <span class="mono inline-block px-2 py-1 text-[10px] font-bold tracking-widest uppercase border bg-yellow-50 text-yellow-700 border-yellow-200">
                        Pending Confirmation
                    </span>
                }
            </div>
        </div>
    </div>

    @if (Model.Technician != null)
    {
        /* Technician section with metadata*/
        <div class="mt-6 bg-white border-2 border-gray-200">
            <div class="px-4 sm:px-6 py-4 border-b-2 border-gray-200 bg-gray-50">
                <div class="flex items-center gap-3">
                    <svg class="w-5 h-5 text-[#02f1b4]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                    <span class="mono text-xs tracking-widest uppercase text-gray-600 font-bold">
                        Technician Profile
                    </span>
                </div>
            </div>
            
            <div class="p-6 space-y-4">
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                    <div>
                        <div class="mono text-[10px] tracking-widest uppercase text-gray-400 font-bold mb-2">
                            Hire Date
                        </div>
                        <div class="mono text-sm text-gray-600">
                            @Model.Technician.HireDate.ToString("MMMM dd, yyyy")
                        </div>
                    </div>

                    <div>
                        <div class="mono text-[10px] tracking-widest uppercase text-gray-400 font-bold mb-2">
                            Status
                        </div>
                        @if (Model.Technician.IsActive)
                        {
                            <span class="mono inline-block px-2 py-1 text-[10px] font-bold tracking-widest uppercase border bg-green-50 text-green-700 border-green-200">
                                Active
                            </span>
                        }
                        else
                        {
                            <span class="mono inline-block px-2 py-1 text-[10px] font-bold tracking-widest uppercase border bg-gray-50 text-gray-700 border-gray-200">
                                Inactive
                            </span>
                        }
                    </div>

                    <div>
                        <div class="mono text-[10px] tracking-widest uppercase text-gray-400 font-bold mb-2">
                            Skills
                        </div>
                        <div class="mono text-sm text-gray-600">
                            @Model.Technician.TechnicianSkills.Count skill@(Model.Technician.TechnicianSkills.Count == 1 ? "" : "s")
                        </div>
                    </div>
                </div>

                <div class="pt-4 border-t border-gray-200">
                    <a asp-controller="Technicians" asp-action="Details" asp-route-id="@Model.Technician.Id"
                       class="mono tracking-[0.1em] inline-flex items-center gap-2 px-4 py-2 text-[10px] font-bold uppercase
                              border border-gray-300 text-gray-600
                              hover:border-[#041f41] hover:text-[#041f41] transition">
                        View Full Technician Profile →
                    </a>
                </div>
            </div>
        </div>
    }

    @* Action buttons *@
    <div class="mt-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <a asp-action="Index"
           class="mono tracking-[0.15em] px-4 py-2.5 text-xs font-bold uppercase text-center border-2 border-gray-300 text-gray-600 hover:border-[#041f41] hover:text-[#041f41] transition w-full sm:w-auto">
            ← Back to List
        </a>
        
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" 
              onsubmit="return confirm('Are you sure you want to delete @Model.FullName? This action cannot be undone.');"
              class="w-full sm:w-auto">
            <button type="submit"
                    class="mono tracking-[0.15em] flex items-center justify-center gap-2 px-4 py-2.5 text-xs font-bold uppercase border-2 border-red-300 text-red-600 hover:bg-red-600 hover:text-white hover:border-red-600 transition w-full">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
                Delete User
            </button>
        </form>
    </div>
</div>
