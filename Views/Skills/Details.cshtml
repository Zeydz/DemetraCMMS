@model dotnet_projektuppgift.Models.Entities.Skill

@{
    ViewData["Title"] = "Skill Details";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="max-w-4xl">

    @* Breadcrumb*@
    <div class="mb-6">
        <a asp-action="Index" class="mono text-xs tracking-widest uppercase text-gray-400 hover:text-[#041f41] transition">
            ← Back to Skills
        </a>
    </div>

    <div class="mb-8 flex items-start justify-between gap-4">
        <div>
            <div class="flex items-center gap-3 mb-3">
                <span class="w-1.5 h-1.5 bg-[#02f1b4] inline-block"></span>
                <span class="mono text-[10px] tracking-[0.25em] text-[#02f1b4] uppercase font-bold">
                    Skill Details
                </span>
            </div>
            <h2 class="text-2xl sm:text-3xl font-black text-[#041f41]">@Model.Name</h2>
        </div>
        
        @* Page header *@
        <div class="flex items-center gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id"
               class="mono tracking-[0.15em] flex items-center gap-2 px-4 py-2.5 text-xs font-bold uppercase
                      border-2 border-[#02f1b4] text-[#02f1b4]
                      hover:bg-[#02f1b4] hover:text-[#041f41] transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
                Edit
            </a>
        </div>
    </div>

    @* Main card *@
    <div class="bg-white border-2 border-gray-200 p-6 sm:p-8 space-y-6">
        <div>
            <div class="mono text-[10px] tracking-widest uppercase text-gray-400 font-bold mb-2">
                Description
            </div>
            @* Checks if description exists*@
            <div class="text-sm text-gray-600 leading-relaxed">
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    @Model.Description
                }
                else
                {
                    <span class="text-gray-400 italic">No description provided</span>
                }
            </div>
        </div>

        @* Skill ID*@
        <div class="pt-6 border-t-2 border-gray-100">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
                <div>
                    <div class="mono text-[10px] tracking-widest uppercase text-gray-400 font-bold mb-2">
                        Skill ID
                    </div>
                    <div class="mono text-sm text-gray-600">
                        #@Model.Id
                    </div>
                </div>

                @* Technicians with Skill*@
                <div>
                    <div class="mono text-[10px] tracking-widest uppercase text-gray-400 font-bold mb-2">
                        Technicians with Skill
                    </div>
                    <div class="mono text-sm text-gray-600">
                        @Model.TechnicianSkills.Count technician@(Model.TechnicianSkills.Count == 1 ? "" : "s")
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* If there are any TechnicianSkills*@
    @if (Model.TechnicianSkills.Any())
    {
        <div class="mt-6 bg-white border-2 border-gray-200">
            <div class="px-4 sm:px-6 py-4 border-b-2 border-gray-200 bg-gray-50">
                <div class="flex items-center gap-3">
                    <svg class="w-5 h-5 text-[#02f1b4]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    <span class="mono text-xs tracking-widest uppercase text-gray-600 font-bold">
                        Technicians with This Skill
                    </span>
                </div>
            </div>
            
            <div class="divide-y divide-gray-100">
                @* Foreach loop, print out data *@
                @foreach (var techSkill in Model.TechnicianSkills)
                {

                    var techName = techSkill.Technician?.Name ?? "Unknown";
                    var techEmail = techSkill.Technician?.Email ?? "";

                    <div class="px-4 sm:px-6 py-4 hover:bg-gray-50 transition">
                        <div class="flex flex-col sm:hidden gap-3">
                            <div class="flex items-center gap-3">
                                <div class="flex-1 min-w-0">
                                    <div class="font-bold text-sm text-[#041f41] truncate">@techName</div>
                                    <div class="text-xs text-gray-500 truncate">@techEmail</div>
                                </div>
                            </div>

                            <div class="text-xs text-gray-500 ml-13">
                                <span class="mono tracking-widest uppercase text-gray-400 font-bold">Assigned:</span>
                                <span class="ml-2 font-semibold text-[#041f41]">@techSkill.AssignedDate.ToString("MMM dd, yyyy")</span>
                            </div>

                            @* View Technician Profile*@
                            <a asp-controller="Technicians" asp-action="Details" asp-route-id="@techSkill.TechnicianId"
                               class="mono tracking-[0.1em] px-3 py-2 text-[10px] font-bold uppercase text-center border border-gray-300 text-gray-600 hover:border-[#041f41] hover:text-[#041f41] transition w-full">
                                View Profile
                            </a>
                        </div>

                        <div class="hidden sm:flex items-center justify-between">
                            <div class="flex items-center gap-3 flex-1 min-w-0">
                                <div class="flex-1 min-w-0">
                                    <div class="font-bold text-sm text-[#041f41] truncate">@techName</div>
                                    <div class="text-xs text-gray-500 truncate">@techEmail</div>
                                </div>
                            </div>

                            <div class="flex items-center gap-4 ml-4">
                                <div class="text-xs text-gray-500 hidden lg:block">
                                    <span class="mono tracking-widest uppercase text-gray-400 font-bold">Assigned:</span>
                                    <span class="ml-2 font-semibold text-[#041f41]">@techSkill.AssignedDate.ToString("MMM dd, yyyy")</span>
                                </div>
                                <a asp-controller="Technicians" asp-action="Details" asp-route-id="@techSkill.TechnicianId"
                                   class="mono tracking-[0.1em] px-3 py-1.5 text-[10px] font-bold uppercase border border-gray-300 text-gray-600 hover:border-[#041f41] hover:text-[#041f41] transition whitespace-nowrap">
                                    View Profile
                                </a>
                            </div>
                        </div>
                    </div>


                }
            </div>
        </div>
    }
    else
    {
        <div class="mt-6 bg-gray-50 border-2 border-gray-200 p-6 text-center">
            <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <p class="text-sm text-gray-500">No technicians have this skill yet.</p>
        </div>
    }

    <div class="mt-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <a asp-action="Index"
           class="mono tracking-[0.15em] px-4 py-2.5 text-xs font-bold uppercase text-center border-2 border-gray-300 text-gray-600 hover:border-[#041f41] hover:text-[#041f41] transition w-full sm:w-auto">
            ← Back to List
        </a>
        
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" 
              onsubmit="return confirm('Are you sure you want to delete @Model.Name? This action cannot be undone.');"
              class="w-full sm:w-auto">
            <button type="submit"
                    class="mono tracking-[0.15em] flex items-center justify-center gap-2 px-4 py-2.5 text-xs font-bold uppercase border-2 border-red-300 text-red-600 hover:bg-red-600 hover:text-white hover:border-red-600 transition w-full">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
                Delete Skill
            </button>
        </form>
    </div>

</div>
