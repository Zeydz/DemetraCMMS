@model dotnet_projektuppgift.Models.Entities.Location

@{
    ViewData["Title"] = "Location Details";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="max-w-4xl">

    @* Breadcrumb *@
    <div class="mb-6">
        <a asp-action="Index" class="mono text-xs tracking-widest uppercase text-gray-600 hover:text-[#041f41] transition">
            ← Back to Locations
        </a>
    </div>

    @* Page header *@
    <div class="mb-8 flex items-start justify-between">
        <div>
            <div class="flex items-center gap-3 mb-3">
                <span class="w-1.5 h-1.5 bg-[#02f1b4] inline-block"></span>
                <span class="mono text-[10px] tracking-[0.25em] text-[#02f1b4] uppercase font-bold">
                    Location Details
                </span>
            </div>
            <h2 class="text-3xl font-black text-[#041f41]">@Model.Name</h2>
        </div>
        
        @* Action buttons *@
        <div class="flex items-center gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id"
               class="mono tracking-[0.15em] flex items-center gap-2 px-4 py-2.5 text-xs font-bold uppercase
                      border-2 border-[#02f1b4] text-[#02f1b4]
                      hover:bg-[#02f1b4] hover:text-[#041f41] transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
                Edit
            </a>
        </div>
    </div>

    @* Details card *@
    <div class="bg-white border-2 border-gray-200 p-8 space-y-6">

        @* Location info grid *@
        <div class="grid grid-cols-2 gap-6">
            
            @* Building *@
            <div>
                <div class="mono text-[10px] tracking-widest uppercase text-gray-400 font-bold mb-2">
                    Building
                </div>
                <div class="text-lg font-bold text-[#041f41]">
                    @Model.Building
                </div>
            </div>

            <!-- Floor -->
            <div>
                <div class="mono text-[10px] tracking-widest uppercase text-gray-400 font-bold mb-2">
                    Floor
                </div>
                <div class="text-lg font-bold text-[#041f41]">
                    @Model.Floor
                </div>
            </div>

        </div>

        @* Description *@
        <div class="pt-6 border-t-2 border-gray-100">
            <div class="mono text-[10px] tracking-widest uppercase text-gray-400 font-bold mb-2">
                Description
            </div>
            <div class="text-sm text-gray-600 leading-relaxed">
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    @Model.Description
                }
                else
                {
                    <span class="text-gray-400 italic">No description provided</span>
                }
            </div>
        </div>

        @* Meta-data*@
        <div class="pt-6 border-t-2 border-gray-100">
            <div class="grid grid-cols-2 gap-6">
                
                @* Created date *@
                <div>
                    <div class="mono text-[10px] tracking-widest uppercase text-gray-400 font-bold mb-2">
                        Created
                    </div>
                    <div class="mono text-sm text-gray-600">
                        @Model.CreatedAt.ToString("MMMM dd, yyyy 'at' HH:mm")
                    </div>
                </div>

                @* Location ID *@
                <div>
                    <div class="mono text-[10px] tracking-widest uppercase text-gray-400 font-bold mb-2">
                        Location ID
                    </div>
                    <div class="mono text-sm text-gray-600">
                        #@Model.Id
                    </div>
                </div>

            </div>
        </div>

    </div>

    @* Related equipment (I will fix this later on, currently only a placeholder) *@
    <div class="mt-6 bg-gray-50 border-2 border-gray-200 p-6">
        <div class="flex items-center gap-3 mb-4">
            <svg class="w-5 h-5 text-[#02f1b4]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span class="mono text-xs tracking-widest uppercase text-gray-600 font-bold">
                Equipment at this Location
            </span>
        </div>
        <p class="text-sm text-gray-500">
            Equipment list will be shown here once the Equipment module is implemented.
        </p>
    </div>

    @* Bottom actions *@
    <div class="mt-8 flex items-center justify-between">
        <a asp-action="Index"
           class="mono tracking-[0.15em] px-6 py-3 text-xs font-bold uppercase
                  border-2 border-gray-300 text-gray-600
                  hover:border-[#041f41] hover:text-[#041f41] transition">
            ← Back to List
        </a>
        
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" 
              onsubmit="return confirm('Are you sure you want to delete @Model.Name? This action cannot be undone.');"
              class="inline">
            <button type="submit"
                    class="cursor-pointer mono tracking-[0.15em] flex items-center gap-2 px-6 py-3 text-xs font-bold uppercase
                           border-2 border-red-300 text-red-600
                           hover:bg-red-600 hover:text-white hover:border-red-600 transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
                Delete Location
            </button>
        </form>
    </div>

</div>
